{
  "api_key": "${OC_GO_CC_API_KEY}",
  "host": "${OC_GO_CC_HOST}",
  "port": 3456,
  "hot_reload": false,

  "opencode_go": {
    "base_url": "http://192.168.50.150:8080/v1/chat/completions",
    "anthropic_base_url": "http://192.168.50.150:8080/v1/chat/completions",
    "timeout_ms": 300000
  },

  "models": {
    "background": {
      "provider": "opencode-go",
      "model_id": "qwen3.5-plus",
      "temperature": 0.5,
      "max_tokens": 2048
    },
    "default": {
      "provider": "opencode-go",
      "model_id": "kimi-k2.7-code",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "fast": {
      "provider": "opencode-go",
      "model_id": "qwen3.6-plus",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "think": {
      "provider": "opencode-go",
      "model_id": "glm-5",
      "temperature": 0.7,
      "max_tokens": 8192
    },
    "complex": {
      "provider": "opencode-go",
      "model_id": "glm-5.1",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "long_context": {
      "provider": "opencode-go",
      "model_id": "minimax-m3",
      "temperature": 0.7,
      "max_tokens": 16384,
      "context_threshold": 80000
    }
  },

  "fallbacks": {
