# ═══════════════════════════════════════════════════════════════════════
# claude-router configuration template
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ─── Raspberry Pi 4 (opencode-smart-router host) ─────────────────────────
RPI4_IP=192.168.50.150

# ─── oc-go-cc ──────────────────────────────────────────────────────────
# The proxy listens on 3456 (default port, no remapping needed).
# API key is "unused" because the smart-router handles real key rotation.
# NOTE: Upstream URLs are now configured in oc-go-cc/config.json (both base_url
# and anthropic_base_url). Do NOT set OC_GO_CC_OPENCODE_URL here — it overrides
# config.json's base_url and strips the /chat/completions path, breaking routing.
OC_GO_CC_HOST=0.0.0.0
OC_GO_CC_API_KEY=unused
OC_GO_CC_LOG_LEVEL=info

# ─── Grafana ────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Prometheus ─────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d