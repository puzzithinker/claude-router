# ═══════════════════════════════════════════════════════════════════════
# claude-router configuration template
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ─── Raspberry Pi 4 (opencode-smart-router host) ─────────────────────────
RPI4_IP=192.168.50.150

# ─── oc-go-cc ──────────────────────────────────────────────────────────
# The proxy listens on 3456 (default port, no remapping needed).
# API key is "dummy" because the smart-router handles real key rotation.
# OPENCODE_URL must include the full path ending in /chat/completions.
OC_GO_CC_HOST=0.0.0.0
OC_GO_CC_API_KEY=dummy
OC_GO_CC_OPENCODE_URL=http://192.168.50.150:8080/v1/chat/completions
OC_GO_CC_LOG_LEVEL=info

# ─── Grafana ────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Prometheus ─────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d